generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  cedula    String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model PreUser {
  id        String   @id @default(uuid())
  cedula    String   @unique
  email     String   @unique
  name      String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Client {
  id String @id @default(uuid())

  name      String
  cedula    String   @unique
  address   String
  birthDate DateTime

  email  String  @unique
  phone  String
  phone2 String?

  profileImage String?

  createdAt DateTime @default(now())

  bankAccounts BankAccount[]
  credentials  BankCredential?

  loans Loan[]
}

model BankAccount {
  id String @id @default(uuid())

  bankName      String
  accountNumber String
  accountType   String

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
}

model BankCredential {
  id String @id @default(uuid())

  username String
  password String

  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id])
}

model Loan {
  id String @id @default(uuid())

  principalAmount  Float
  remainingBalance Float

  interestRate Float

  frequency PaymentFrequency // MONTHLY o BIWEEKLY

  startDate DateTime

  lastPaymentDate DateTime
  nextDueDate     DateTime

  status LoanStatus @default(ACTIVE)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())
}

model Payment {
  id String @id @default(uuid())

  amount Float

  interestPaid  Float
  principalPaid Float

  remainingBalance Float

  daysCalculated Int

  paymentDate DateTime @default(now())

  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])
}

enum PaymentFrequency {
  MONTHLY // 30 días
  BIWEEKLY // 15 días
}

enum LoanStatus {
  ACTIVE
  PAID
  LATE
}
